# Variáveis de ambiente do Agente Python — Organizador

# ─── Supabase ───────────────────────────────────────────────────────────────
# URL do seu projeto Supabase (encontre em: Dashboard > Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key (NUNCA exponha no frontend!)
# Encontre em: Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Chave da OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Modelo a usar (recomendado: gpt-4o para melhor compreensão em PT-BR)
OPENAI_MODEL=gpt-4o

# ─── UazAPI ─────────────────────────────────────────────────────────────────
# URL base da instância UazAPI (ex: http://localhost:5000 ou URL do servidor)
UAZAPI_URL=http://localhost:5000

# Token de autenticação da instância UazAPI
UAZAPI_TOKEN=seu_token_aqui

# Nome da instância UazAPI
UAZAPI_INSTANCE=organizador

# ─── Agente ──────────────────────────────────────────────────────────────────
# Porta onde o FastAPI vai rodar (padrão: 8001)
AGENT_PORT=8001

# Token secreto para validar requisições do webhook WazAPI
WEBHOOK_SECRET=gere_um_token_seguro_aqui
